menuconfig JOYSTICK_MOUSE
    bool "Joystick Mouse Driver"
    default y
    help
        Enable joystick as mouse driver

if JOYSTICK_MOUSE

config JOYSTICK_POLLING_INTERVAL
    int "Joystick polling interval (ms)"
    default 20
    range 10 100
    help
        Interval in milliseconds between joystick readings

config JOYSTICK_DEADZONE
    int "Joystick deadzone"
    default 100
    range 0 500
    help
        ADC deadzone to ignore small movements

config JOYSTICK_SPEED
    int "Mouse speed multiplier"
    default 5
    range 1 20
    help
        Speed multiplier for mouse movement

endif