// nice_nano_v2.keymap - 键映射配置

#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/outputs.h>

// ==================================================
// 定义行为
// ==================================================

// --- 鼠标移动行为 ---
// ZMK_MOUSE_MOVE(轴, 方向, 按下时间, 释放时间, 按下时长)
// 轴：X 或 Y
// 方向：-1=左/上, 1=右/下
#define JOYSTICK_MOVE_LEFT   ZMK_MOUSE_MOVE(X, -1,  0, 1, 1)
#define JOYSTICK_MOVE_RIGHT  ZMK_MOUSE_MOVE(X,  1,  0, 1, 1)
#define JOYSTICK_MOVE_UP     ZMK_MOUSE_MOVE(Y, -1,  0, 1, 1)
#define JOYSTICK_MOVE_DOWN   ZMK_MOUSE_MOVE(Y,  1,  0, 1, 1)


// ==================================================
// 定义图层 (Layers)
// ==================================================

#define NUM_LAYERS 1

// 层 0: 默认层 (鼠标控制)
// 由于没有按键，我们主要依赖摇杆的模拟功能

// ==================================================
// 键盘映射定义
// ==================================================

/ {
    macros {
        // 如果需要宏定义，可以放在这里
    };

    // 定义图层
    keymap {
        compatible = "zmk,keymap";

        // 层 0
        default_layer {
            // 由于没有物理按键，这里主要处理连接状态
            // 默认启动为USB模式
            bindings = <CONN_USB>;
            
            // 摇杆移动行为
            // ZMK 会自动将摇杆移动映射为鼠标移动
            // 不需要额外定义按键绑定
        };
    };
};
