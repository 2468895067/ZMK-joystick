// nice_nano_v2.dtsi - 设备树配置

#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bits.h>
#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/outputs.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,pointing-device = &joystick0;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-direct";
        label = "KSCAN";
        input-gpios = <&gpio0 10 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
    };

    joystick0: joystick {
        compatible = "zmk,input-analog-joystick";
        label = "JOYSTICK";

        x-input = <&adc 0>;
        y-input = <&adc 1>;

        deadzone = <200>;
        resolution = <12>;
    };
};

&adc {
    status = "okay";
};
